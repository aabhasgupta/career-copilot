# Career Copilot user profile.
# Copy to profile.yaml (gitignored) and fill in your details.
# Everything personal lives here and in data/ - never hardcoded in the app.
#
# identity below can be auto-filled from your resume: after copying this
# file and placing your resume at data/resume.pdf, run `copilot profile fill`.
# search/visa/email_integration are your preferences, not resume facts -
# those always need your own edit.

identity:
  full_name: Jane Doe
  email: jane@example.com
  phone: "+1 555 000 0000"
  location: San Francisco, CA
  links:
    linkedin: https://linkedin.com/in/janedoe
    github: https://github.com/janedoe
    portfolio: null

resume_path: data/resume.pdf

search:
  # Titles the discovery agent queries for. Be specific but not narrow.
  titles:
    - Software Engineer
    - Backend Engineer
  locations:
    - United States
  # (There is deliberately no remote yes/no toggle: put "remote" first in
  # location_preference below to prefer remote, or add a dealbreaker like
  # "no fully onsite jobs" to require it.)
  # Salary floor: hides jobs whose known salary is below this. Jobs that
  # don't state a salary are always kept ("unknown, never dropped").
  min_salary: null     # e.g. 120000; null = no floor
  salary_currency: USD
  # Hard filters: jobs matching any of these are dropped, not just downranked.
  # Plain English - Claude compiles these into precise filters (cached until
  # the list changes). e.g. ["no clearance jobs", "don't give me jobs based
  # in Alabama", "nothing at Meta"]
  dealbreakers: []
  # Ordering, not filtering: listings are sorted by these, most preferred
  # first; jobs matching nothing sort last but stay visible.
  # Entry forms: "remote", "within <N> miles of <place>", or plain text
  # matched against the job's location.
  location_preference: []  # e.g. ["remote", "Chicago, IL", "within 30 miles of Naperville, IL"]
  # Industries you fit best, most preferred first. Companies are classified
  # once by the LLM into this vocabulary: banking, fintech, insurance,
  # healthcare, tech, consulting, staffing, government, retail, manufacturing,
  # energy, education, media, nonprofit, other.
  industry_preference: []  # e.g. ["fintech", "banking", "tech"]
  # Direct employer postings rank above staffing-agency postings; set false
  # (or list "staffing" above) if agency roles are fine for you.
  deprioritize_staffing: true
  # Companies you'd love to work for, most preferred first. Their listings
  # rank higher, and their public Greenhouse/Lever/Ashby boards are
  # auto-watchlisted so their postings arrive with direct apply links.
  company_preference: []  # e.g. ["Stripe", "Anthropic"]

visa:
  needs_sponsorship: true
  # none | f1_opt | stem_opt | h1b_transfer | other
  status: h1b_transfer

email_integration:
  provider: outlook    # outlook | gmail
  address: jane@hotmail.com

llm:
  model: claude-sonnet-5
